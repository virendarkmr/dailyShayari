  {"id":"quotes_006","text":"Your mindset determines your future.","category":"quotes","createdAt":1706550000000,"updatedAt":1706550000000},
  {"id":"quotes_007","text":"Small progress is still progress.","category":"quotes","createdAt":1706540000000,"updatedAt":1706540000000},
  {"id":"quotes_008","text":"Stay positive, work hard, make it happen.","category":"quotes","createdAt":1706530000000,"updatedAt":1706530000000},
