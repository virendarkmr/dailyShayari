  {"id":"love_018","text":"When I see you smile, my whole day becomes brighter.","category":"love","createdAt":1706480000000,"updatedAt":1706480000000},
  {"id":"love_019","text":"तुम्हारे बिना सब अधूरा सा लगता है।","category":"love","createdAt":1706470000000,"updatedAt":1706470000000},
  {"id":"love_020","text":"Love begins with a smile and grows with trust.","category":"love","createdAt":1706460000000,"updatedAt":1706460000000},

  {"id":"sad_016","text":"कभी कभी अकेलापन ही सबसे सच्चा साथी होता है।","category":"sad","createdAt":1706450000000,"updatedAt":1706450000000},
  {"id":"sad_017","text":"दिल की चोट दिखती नहीं, पर महसूस बहुत होती है।","category":"sad","createdAt":1706440000000,"updatedAt":1706440000000},
